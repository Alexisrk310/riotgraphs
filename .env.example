# ─────────────────────────────────────────────────────────────
# RiotGraphs — environment variables
# Copy to .env.local and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RiotGraphs

# --- Riot Games API ---
# https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_API_KEY_VALORANT=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional Riot Sign-On (OAuth) — requires production approval
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
RIOT_REDIRECT_URI=http://localhost:3000/api/auth/callback/riot

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://riotgraphs:riotgraphs@localhost:5432/riotgraphs?schema=public
DIRECT_URL=postgresql://riotgraphs:riotgraphs@localhost:5432/riotgraphs?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379
# Upstash (edge rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- ClickHouse (analytics OLAP) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=riotgraphs_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Auth ---
AUTH_SECRET=change-me-in-production-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Stripe (monetization) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxx
STRIPE_PRICE_API_STARTER=price_xxx
STRIPE_PRICE_API_PRO=price_xxx

# --- Abacus.AI RouteLLM (AI insights) ---
ABACUS_API_KEY=
ABACUS_ROUTELLM_BASE_URL=https://api.abacus.ai/v1
ABACUS_ROUTELLM_MODEL=route-llm

# --- Observability ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
PROMETHEUS_ENABLED=true

# --- Feature flags ---
FEATURE_VALORANT=true
FEATURE_TFT=true
FEATURE_LOR=true
FEATURE_WILD_RIFT=false
FEATURE_AI_INSIGHTS=true

# --- Rate limiting ---
RATE_LIMIT_ANON_PER_MINUTE=30
RATE_LIMIT_USER_PER_MINUTE=120
RATE_LIMIT_PREMIUM_PER_MINUTE=600
